@bot_owner_or_permission(kick_members=True)
async def warn(ctx, member: discord.Member = None, *, reason: str = None):
    if member is None or reason is None:
        await ctx.send("❌ Utilisation : `!warn @utilisateur raison`")
        return
    if member == ctx.author:
        await ctx.send("❌ Tu ne peux pas te warn toi-même !")
        return
    if member.bot:
        await ctx.send("❌ Tu ne peux pas warn un bot.")
        return
    count = add_warn(ctx.guild.id, member.id, reason, ctx.author.name)
    try:
        await member.send(
            f"⚠️ Tu as reçu un avertissement sur **{ctx.guild.name}**.\n"
            f"**Raison :** {reason}\n"
            f"**Par :** {ctx.author.name}\n"
            f"**Avertissements :** {count}/{MAX_WARNS}"
