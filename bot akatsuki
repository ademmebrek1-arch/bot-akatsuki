        await member.ban(reason="Aucune raison fournie")
        await ctx.send(f"🔨 **{member.name}** a été banni.")
        await derank_member(ctx.guild, ctx.author, ctx.channel)
    else:
        await member.ban(reason=reason)
        await ctx.send(f"🔨 **{member.name}** a été banni. Raison : *{reason}*")

