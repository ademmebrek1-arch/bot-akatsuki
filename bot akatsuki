import os
import json
import random
import asyncio
from datetime import datetime, timedelta, timezone
import discord
from discord.ext import commands

WARNS_FILE = "warns.json"
OWNERS_FILE = "owners.json"
MAX_WARNS = 3

# ── Anti-raid state (in memory) ────────────────────────────────
RAID_THRESHOLD = 5       # membres en
RAID_WINDOW    = 10      # secondes → raid détecté
antiraid_enabled = {}    # {guild_id: bool}
join_log         = {}    # {guild_id: [datetime, ...]}
raid_active      = {}    # {guild_id: bool}

# ── Anti-spam state (in memory) ────────────────────────────────
SPAM_LIMIT  = 5          # même message X fois
SPAM_WINDOW = 10         # en Y secondes → ban auto
spam_log    = {}         # {(guild_id, user_id): [(content, datetime), ...]}

# ── Warns helpers ──────────────────────────────────────────────

def load_warns():
    if os.path.exists(WARNS_FILE):
        with open(WARNS_FILE, "r") as f:
            return json.load(f)
    return {}

def save_warns(data):
    with open(WARNS_FILE, "w") as f:
        json.dump(data, f, indent=2)

def get_user_warns(guild_id, user_id):
    data = load_warns()
    return data.get(str(guild_id), {}).get(str(user_id), [])

def add_warn(guild_id, user_id, reason, by):
    data = load_warns()
    guild_data = data.setdefault(str(guild_id), {})
    user_warns = guild_data.setdefault(str(user_id), [])
    user_warns.append({
        "reason": reason,
        "by": by,
        "at": datetime.utcnow().strftime("%d/%m/%Y %H:%M UTC")
    })
    save_warns(data)
    return len(user_warns)

def clear_warns(guild_id, user_id):
    data = load_warns()
    data.get(str(guild_id), {}).pop(str(user_id), None)
    save_warns(data)

# ── Owners helpers ─────────────────────────────────────────────

def load_owners():
    if os.path.exists(OWNERS_FILE):
        with open(OWNERS_FILE, "r") as f:
            return json.load(f)
    return {}

def save_owners(data):
    with open(OWNERS_FILE, "w") as f:
        json.dump(data, f, indent=2)

def is_bot_owner(guild_id, user_id):
    data = load_owners()
    return user_id in data.get(str(guild_id), [])

def add_bot_owner(guild_id, user_id):
    data = load_owners()
    owners = data.setdefault(str(guild_id), [])
    if user_id not in owners:
        owners.append(user_id)
    save_owners(data)

def remove_bot_owner(guild_id, user_id):
    data = load_owners()
    owners = data.get(str(guild_id), [])
    if user_id in owners:
        owners.remove(user_id)
    save_owners(data)

# ── Custom permission check ────────────────────────────────────

def bot_owner_or_permission(**perms):
    async def predicate(ctx):
        if ctx.guild and is_bot_owner(ctx.guild.id, ctx.author.id):
            return True
        missing = [
            perm for perm, value in perms.items()
            if getattr(ctx.author.guild_permissions, perm, None) != value
        ]
        if missing:
            raise commands.MissingPermissions(missing)
        return True
    return commands.check(predicate)

