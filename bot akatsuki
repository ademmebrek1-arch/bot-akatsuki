    if member is None:
        await ctx.send("❌ Mentionne un membre à bannir. Exemple : `!ban @utilisateur raison`")
        return
    if member == ctx.author:
        await ctx.send("❌ Tu ne peux pas te bannir toi-même !")
        return
    if member.top_role >= ctx.author.top_role and not is_bot_owner(ctx.guild.id, ctx.author.id):
        await ctx.send("❌ Tu ne peux pas bannir un membre avec un rôle égal ou supérieur au tien.")
