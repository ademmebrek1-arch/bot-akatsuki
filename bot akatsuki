import asyncio, sys

async def launch():
    raw = os.environ.get("DISCORD_TOKEN", "")
    token = raw.strip()
    if not token:
        print("❌  DISCORD_TOKEN manquant. Ajoutez-le dans les Secrets.")
        sys.exit(1)
    print(f"🔄  Démarrage du bot...")
    try:
        async with bot:
            await bot.start(token, reconnect=True)
        print("✅  Bot arrêté proprement.")
    except discord.errors.LoginFailure as e:
        print(f"❌  Token refusé par Discord : {e}")
        print("    → Allez sur discord.com/developers → Bot → Reset Token")
        sys.exit(1)
    except Exception as e:
        print(f"⚠️  Crash : {type(e).__name__}: {e}")
        print("⏳  Redémarrage dans 5s...")
        import time; time.sleep(5)
        os.execv(sys.executable, [sys.executable] + sys.argv)

asyncio.run(launch())
@bot.command(name="leaderboard", aliases=["lb", "classement"])
async def leaderboard(ctx):
    # 1. Charger les données du fichier coins.json
    try:
        with open("coins.json", "r") as f:
            data = json.load(f)
    except FileNotFoundError:
        await ctx.send("❌ Aucun classement disponible pour le moment (fichier introuvable).")
        return

    # 2. Trier les utilisateurs par nombre de coins décroissant
    # data.items() donne (user_id, solde) -> on trie sur le solde (x[1])
    sorted_players = sorted(data.items(), key=lambda x: x[1], reverse=True)

    if not sorted_players:
        await ctx.send("🪙 Personne n'a encore de coins sur ce serveur !")
        return

    # 3. Construire le texte du classement (Top 10 maximum)
    leaderboard_text = "🏆 **CLASSEMENT DES PLUS RICHES (AKATSUKI)** 🏆\n\n"

    count = 0
    for user_id, coins in sorted_players:
        if count >= 10:  # On s'arrête au top 10
            break

        # On essaie de récupérer le nom de l'utilisateur sur le serveur
        member = ctx.guild.get_member(int(user_id))
        if member:
            username = member.display_name
        else:
            username = f"Utilisateur inconnu ({user_id})"

        # Petites médailles pour le podium
        if count == 0:
            medal = "🥇"
        elif count == 1:
            medal = "🥈"
        elif count == 2:
            medal = "🥉"
        else:
            medal = f"#{count + 1}"

        leaderboard_text += f"{medal} **{username}** — {coins} coins 🪙\n"
        count += 1

    # 4. Envoyer le message final dans le salon Discord
    await ctx.send(leaderboard_text)
asyncio.run(launch())
