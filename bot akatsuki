    except discord.Forbidden:
        pass
    if count >= MAX_WARNS:
        clear_warns(ctx.guild.id, member.id)
        await ctx.send(
            f"⚠️ **{member.name}** a reçu son **{count}ème avertissement** (raison : *{reason}*).\n"
            f"🔨 Il a atteint **{MAX_WARNS} warns** et a été automatiquement **banni** !"
        )
        await member.ban(reason=f"Banni automatiquement après {MAX_WARNS} avertissements.")
    else:
        remaining = MAX_WARNS - count
        await ctx.send(
            f"⚠️ **{member.name}** a reçu un avertissement ({count}/{MAX_WARNS}). Raison : *{reason}*\n"
            f"{'⛔ Encore **1 warn** avant le ban !' if remaining == 1 else f'Il lui reste **{remaining} warns** avant le ban.'}"
        )

